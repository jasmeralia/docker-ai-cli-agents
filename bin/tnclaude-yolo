#!/usr/bin/env bash

set -euo pipefail

# Run Claude Code without the Docker socket mount so the agent cannot access
# host Docker. Permission prompts are already suppressed by the entrypoint.
unset SANDBOX_DOCKER

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "${script_dir}/../scripts/run_with_truenas_mounts.sh" --claude-yolo "$@"
