#!/usr/bin/env bash

set -euo pipefail

# Run Codex with the Docker socket mounted but only trusted read-only commands
# (ls, cat, sed, etc.) auto-approved. Any command not in the trusted set,
# including Docker commands, will escalate for approval.
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "${script_dir}/../scripts/run_with_truenas_mounts.sh" --codex-safe "$@"
